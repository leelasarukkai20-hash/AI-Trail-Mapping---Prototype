# Strava OAuth — get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Scopes requested at authorize time (comma-separated, no spaces)
STRAVA_SCOPES=activity:read_all,profile:read_all

# Base URL of the app. Local dev: http://localhost:3000
# Production: your Vercel URL, e.g. https://marin-trails.vercel.app
APP_BASE_URL=http://localhost:3000

# Secret used to sign the OAuth state cookie (any long random string).
# Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=

# --- App services ---
# Anthropic API key for intent parsing (Claude Haiku). https://console.anthropic.com
ANTHROPIC_API_KEY=

# Mapbox public token for the map (starts with pk.). https://account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Database (Neon Postgres, via the Vercel + Neon integration) ---
# Set automatically in production by the integration. Locally, pull it with
# `vercel env pull .env.local` or copy the connection string from the Neon dashboard.
DATABASE_URL=
